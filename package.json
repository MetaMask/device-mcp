{
  "name": "@metamask/device-mcp",
  "version": "0.1.0",
  "description": "MCP server for mobile device interaction — iOS (IDB), Android (ADB), and Appium/BrowserStack",
  "homepage": "https://github.com/MetaMask/device-mcp#readme",
  "bugs": {
    "url": "https://github.com/MetaMask/device-mcp/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/MetaMask/device-mcp.git"
  },
  "license": "(MIT OR Apache-2.0)",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "bin": "./dist/cli/device-mcp.mjs",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "ts-bridge --project tsconfig.build.json --clean",
    "build:docs": "typedoc",
    "clean": "rm -rf dist",
    "dev": "tsc --watch",
    "lint": "yarn lint:eslint && yarn lint:constraints && yarn lint:misc --check && yarn lint:dependencies --check && yarn lint:changelog",
    "lint:changelog": "auto-changelog validate --prettier",
    "lint:constraints": "yarn constraints",
    "lint:dependencies": "depcheck && yarn dedupe --check",
    "lint:dependencies:fix": "depcheck && yarn dedupe",
    "lint:eslint": "eslint .",
    "lint:fix": "yarn lint:eslint --fix && yarn lint:constraints --fix && yarn lint:misc --write && yarn lint:dependencies:fix && yarn lint:changelog",
    "lint:misc": "prettier '**/*.json' '**/*.md' '**/*.yml' '!.yarnrc.yml' --ignore-path .gitignore --no-error-on-unmatched-pattern",
    "prepack": "./scripts/prepack.sh",
    "start": "node dist/index.mjs",
    "test": "vitest",
    "test:watch": "vitest --watch"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@lavamoat/allow-scripts": "^3.0.4",
    "@lavamoat/preinstall-always-fail": "^2.0.0",
    "@metamask/auto-changelog": "^5.3.0",
    "@metamask/eslint-config": "^15.0.0",
    "@metamask/eslint-config-nodejs": "^15.0.0",
    "@metamask/eslint-config-typescript": "^15.0.0",
    "@metamask/eslint-config-vitest": "^15.0.0",
    "@ts-bridge/cli": "^0.6.3",
    "@types/node": "^20.0.0",
    "@typescript-eslint/utils": "^8.6.0",
    "@vitest/coverage-istanbul": "^3.0.7",
    "@vitest/eslint-plugin": "^1.1.4",
    "@yarnpkg/types": "^4.0.0-rc.52",
    "depcheck": "^1.4.3",
    "eslint": "^9.11.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-import-resolver-typescript": "^3.6.3",
    "eslint-plugin-import-x": "^4.3.0",
    "eslint-plugin-jsdoc": "^50.2.4",
    "eslint-plugin-n": "^17.10.3",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-promise": "^7.1.0",
    "prettier": "^3.3.3",
    "prettier-plugin-packagejson": "^2.5.8",
    "ts-node": "^10.7.0",
    "typedoc": "^0.26.11",
    "typescript": "~5.7.3",
    "typescript-eslint": "^8.48.1",
    "vite": "^6.4.1",
    "vitest": "^3.2.1"
  },
  "packageManager": "yarn@4.16.0",
  "engines": {
    "node": "^20 || ^22 || >=24"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "lavamoat": {
    "allowScripts": {
      "@lavamoat/preinstall-always-fail": false,
      "eslint-plugin-import-x>unrs-resolver": false,
      "vite>esbuild": false,
      "vitest>vite-node>vite>esbuild": false,
      "vitest>vite>esbuild": false
    }
  }
}
